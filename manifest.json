{
  "manifest_version": 3,
  "name": "AI Writing Co-Pilot",
  "version": "1.0",
  "description": "Reescribe y mejora tus mensajes con IA en español e inglés",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.facebook.com/*",
    "https://web.whatsapp.com/*",
    "https://mail.google.com/*",
    "https://claude.ai/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.facebook.com/*",
        "https://web.whatsapp.com/*",
        "https://mail.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["panel.css"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
